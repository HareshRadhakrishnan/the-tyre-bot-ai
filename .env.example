# ─── Application ───────────────────────────────────────────────────────────────
PORT=3000

# ─── WhatsApp Cloud API ────────────────────────────────────────────────────────
# Token you set in the Meta developer console when configuring the webhook
VERIFY_TOKEN=your_webhook_verify_token
# Permanent access token from Meta > WhatsApp > API Setup
WHATSAPP_TOKEN=your_whatsapp_bearer_token
# The phone number ID from Meta > WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# ─── Google Sheets ─────────────────────────────────────────────────────────────
# The long ID in the Google Sheets URL
GOOGLE_SHEET_ID=your_google_sheet_id
# Service account email from the GCP credentials JSON
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
# Private key from the GCP credentials JSON — keep newlines as literal \n
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"
# Sheet range to read, e.g. Sheet1!A1:D or Tyres!A:D
GOOGLE_SHEET_RANGE=Sheet1!A:D

# ─── LLM (OpenRouter) ──────────────────────────────────────────────────────────
# API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key
# Any free model on OpenRouter, e.g.:
#   meta-llama/llama-3.3-70b-instruct:free
#   mistralai/mistral-7b-instruct:free
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ─── Bot identity ──────────────────a────────────────────────────────────────────
BOT_BUSINESS_NAME=Ahmed Tyres
